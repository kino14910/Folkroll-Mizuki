{
	"plugins": ["prettier-plugin-astro", "prettier-plugin-svelte"],

	"printWidth": 80,
	"tabWidth": 4,
	"useTabs": true,

	"semi": false,
	"singleQuote": true,
	"quoteProps": "as-needed",
	"trailingComma": "all",
	"bracketSpacing": true,
	"arrowParens": "avoid",
	"endOfLine": "lf",

	"overrides": [
		{
			"files": ["**/*.css"],
			"options": {
				"printWidth": 200,
				"tabWidth": 2,
				"useTabs": false
			}
		}
	]
}
